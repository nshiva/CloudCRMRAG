# Copy this file to .env and replace placeholder values.

# Neo4j Aura
NEO4J_URI=neo4j+s://your-instance-id.databases.neo4j.io
NEO4J_USERNAME=your_neo4j_username
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=your_neo4j_database_name

# RAG ingestion + retrieval settings
DOCS_PATH=support-rag-dataset/docs
VECTOR_INDEX_NAME=chunk_embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
TOP_K=5

# LLM provider settings (used by src/rag.py and app.py)
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=
LLM_TEMPERATURE=0.1

# Optional backward-compatible Ollama aliases
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=
OLLAMA_TEMPERATURE=0.1
